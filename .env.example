VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only Netlify Function env.
# Never expose these with VITE_ prefixes.
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=
OPENAI_BASE_URL=https://api.openai.com/v1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Only set locally for testnet XDR draft generation.
# Do not expose production signing keys in browser builds.
# VITE_STELLAR_TESTNET_SOURCE_SECRET=
